{
  "name": "nodejs-library-template",
  "version": "0.0.1",
  "description": "",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "node --import tsx/esm --test --watch \"tests/**/*.test.ts\"",
    "test": "node --import tsx/esm --test \"tests/**/*.test.ts\"",
    "test:coverage": "node --test-coverage --import tsx/esm --test \"tests/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src tests",
    "lint:fix": "oxlint --fix src tests",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "clean": "rm -rf dist docs",
    "docs": "typedoc",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run clean && npm run build"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "tsx": "latest",
    "typedoc": "^0.28.17",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
